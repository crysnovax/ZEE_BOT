# ════════════════════════════════════════════════
# ZEE BOT - Environment Variables
# ════════════════════════════════════════════════

# Bot Information
BOT_NAME=ZEE BOT
OWNER_NUMBER=2347043550282
PREFIX=.

# Session
SESSION_NAME=zee-session

# Bot Mode
PUBLIC_MODE=false
SELF_BOT=false
AUTO_READ=true
AUTO_TYPING=false
AUTO_RECORDING=false
ALWAYS_ONLINE=true

# Owner Numbers (comma-separated)
OWNER_NUMBERS=2347043550282

# Auto Reply
AUTO_REPLY=true

# Logging
LOG_LEVEL=info

# API Keys (Optional)
OPENAI_API_KEY=
WEATHER_API_KEY=
NEWS_API_KEY=
